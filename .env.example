# ── Bybit API (REQUIRED for live bot) ────────────────────────────────────────
# Create API keys at: https://www.bybit.com/app/user/api-management
# Permissions needed: "Contract — Orders, Positions" (Read + Write)
# IP whitelist: your server IP (recommended)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── HyroTrader challenge bot (hyro-bot.js) ───────────────────────────────────
# Bybit subaccount API key/secret provided by HyroTrader (real api.bybit.com)
# Permissions: "Contract — Orders, Positions" (Read + Write)
HYRO_API_KEY=
HYRO_API_SECRET=
HYRO_INITIAL_BALANCE=10000
# Bot flattens + stops the instant total profit reaches this many USDT.
# Protects gains from being given back. Default 150.
HYRO_PROFIT_LOCK_USD=150

# Kill switch — set to 1 to start the bot in PAUSED mode (no new trades opened).
# Existing positions on Bybit keep their attached stops, so they're protected.
# Risk monitor + Telegram still work; only entries are blocked.
# Remove the env var (or set to 0) and redeploy to resume.
HYRO_PAUSED=0

# ── WhatsApp alerts via CallMeBot (free, optional) ───────────────────────────
# 1. Add +34 644 59 77 71 to your WhatsApp contacts
# 2. Send it: "I allow callmebot to send me messages"
# 3. You'll receive your API key via WhatsApp
WHATSAPP_PHONE=46701234567       # your number with country code, no + sign
WHATSAPP_APIKEY=                 # 6-digit key from CallMeBot
